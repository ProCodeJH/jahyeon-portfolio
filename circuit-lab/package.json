{
  "name": "circuit-lab",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade 3D Arduino Circuit Simulator",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @circuit-lab/web dev",
    "dev:api": "pnpm --filter @circuit-lab/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @circuit-lab/web build",
    "build:api": "pnpm --filter @circuit-lab/api build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0"
  }
}
